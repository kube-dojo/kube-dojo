#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
export PYTHONPATH="${REPO_ROOT}/scripts:${PYTHONPATH:-}"
PYTHON_BIN="${REPO_ROOT}/.venv/bin/python"
if [[ ! -x "${PYTHON_BIN}" && -x "${REPO_ROOT}/../kubedojo/.venv/bin/python" ]]; then
  PYTHON_BIN="${REPO_ROOT}/../kubedojo/.venv/bin/python"
fi
if [[ ! -x "${PYTHON_BIN}" ]]; then
  PYTHON_BIN="python3"
fi

exec "${PYTHON_BIN}" -m pipeline_v2.cli "$@"
