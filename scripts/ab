#!/usr/bin/env bash
# Agent Bridge CLI wrapper for KubeDojo
export AB_REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
export AB_DB_PATH="${AB_REPO_ROOT}/.bridge/messages.db"
export AB_CONTEXT_DIR="${AB_REPO_ROOT}/docs/agent-channels"
export AB_WAKE_DIR="${AB_REPO_ROOT}/.agent/wake"
export AB_PIPELINE_ENV_KEY="KUBEDOJO_PIPELINE"
export PYTHONPATH="${AB_REPO_ROOT}/scripts:${PYTHONPATH}"
exec python3 -m ai_agent_bridge "$@"
