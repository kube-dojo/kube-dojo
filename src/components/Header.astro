---
/**
 * Shared site header for Starlight pages and the standalone homepage.
 * Locale-aware: detects /uk/ prefix and switches labels + hrefs.
 */
import Search from 'virtual:starlight/components/Search';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import LanguageSelect from 'virtual:starlight/components/LanguageSelect';

interface HeaderProps {
  standalone?: boolean;
  langSwitchHref?: string;
  langFlag?: string;
}

const { standalone = false, langSwitchHref, langFlag } = Astro.props as HeaderProps;
const pathname = Astro.url.pathname;
const isUk = pathname.startsWith('/uk/') || pathname === '/uk';
const p = isUk ? '/uk' : '';

const nav = isUk
  ? [
      [`${p}/`, 'Головна'],
      [`${p}/prerequisites/`, 'Основи'],
      [`${p}/linux/`, 'Linux'],
      [`${p}/cloud/`, 'Хмара'],
      [`${p}/ai-ml-engineering/`, 'AI/ML'],
      [`${p}/k8s/`, 'Сертифікації'],
      [`${p}/platform/`, 'Платформа'],
      [`${p}/on-premises/`, 'On-Premises'],
    ]
  : [
      ['/', 'Home'],
      ['/prerequisites/', 'Fundamentals'],
      ['/linux/', 'Linux'],
      ['/cloud/', 'Cloud'],
      ['/ai-ml-engineering/', 'AI/ML'],
      ['/k8s/', 'Certifications'],
      ['/platform/', 'Platform'],
      ['/on-premises/', 'On-Premises'],
    ];
---

<div class="kd-header-shell">
  <div class="kd-topbar">
    <a class="kd-logo" href={`${p}/` || '/'}><span class="kd-logo-icon">K</span><span>KubeDojo</span></a>
    <nav class="kd-nav" aria-label="Primary">
      {nav.map(([href, label]) => <a href={href}>{label}</a>)}
    </nav>
    <div class="kd-right">
      <div class="kd-search"><Search {...Astro.props} /></div>
      <div class="kd-theme"><ThemeSelect {...Astro.props} /></div>
      <div class="kd-social"><SocialIcons {...Astro.props} /></div>
      {
        standalone ? (
          langSwitchHref && langFlag ? (
            <a class="kd-lang-link" href={langSwitchHref} aria-label="Switch language">
              {langFlag}
            </a>
          ) : null
        ) : (
          <div class="kd-lang"><LanguageSelect {...Astro.props} /></div>
        )
      }
      <button
        class="kd-menu-toggle"
        type="button"
        aria-controls="kd-mobile-nav"
        aria-expanded="false"
      >
        Menu
      </button>
    </div>
  </div>
  <div class="kd-mobile-panel" id="kd-mobile-nav" hidden>
    <nav class="kd-mobile-nav" aria-label="Primary mobile">
      {nav.map(([href, label]) => <a href={href}>{label}</a>)}
    </nav>
  </div>
</div>
<script>
  function initHeader() {
    const root = document.querySelector('.kd-header-shell');
    if (!root) return;

    const panel = root.querySelector('.kd-mobile-panel');
    const toggle = root.querySelector('.kd-menu-toggle');
    const pathname = window.location.pathname;
    const isUk = pathname.startsWith('/uk/') || pathname === '/uk';
    const home = isUk ? '/uk/' : '/';

    root.querySelectorAll('.kd-nav a, .kd-mobile-nav a').forEach((anchor) => {
      const href = anchor.getAttribute('href') || '';
      const active = href === home ? pathname === home : pathname.startsWith(href);
      anchor.classList.toggle('active', active);
      anchor.toggleAttribute('aria-current', active);
    });

    if (!(panel instanceof HTMLElement) || !(toggle instanceof HTMLButtonElement)) return;

    const closeMenu = () => {
      panel.hidden = true;
      toggle.setAttribute('aria-expanded', 'false');
    };

    if (!toggle.dataset.bound) {
      toggle.dataset.bound = 'true';
      toggle.addEventListener('click', () => {
        const isOpen = toggle.getAttribute('aria-expanded') === 'true';
        panel.hidden = isOpen;
        toggle.setAttribute('aria-expanded', String(!isOpen));
      });
      root.querySelectorAll('.kd-mobile-nav a').forEach((anchor) => {
        anchor.addEventListener('click', closeMenu);
      });
      window.addEventListener('resize', () => {
        if (window.innerWidth > 800) closeMenu();
      });
    } else {
      closeMenu();
    }
  }

  initHeader();
  document.addEventListener('astro:page-load', initHeader);
</script>

<style>
  /* Exact POC v2 values */
  .kd-header-shell { position: sticky; top: 0; z-index: 100; }
  .kd-topbar { background: white; border-bottom: 1px solid #E5E7EB; padding: 0 2rem; display: flex; align-items: center; gap: 1rem; height: 3.5rem; }
  :global([data-theme='dark']) .kd-topbar { background: #1F2937; border-bottom-color: #374151; }
  .kd-logo { font-weight: 800; font-size: 1.125rem; letter-spacing: -0.5px; display: flex; align-items: center; gap: 0.5rem; color: #0F172A; text-decoration: none; }
  :global([data-theme='dark']) .kd-logo { color: white; }
  .kd-logo-icon { width: 1.75rem; height: 1.75rem; background: #326CE5; border-radius: 0.4rem; display: flex; align-items: center; justify-content: center; color: white; font-size: 0.875rem; font-weight: 900; }
  .kd-nav { display: flex; gap: 0.25rem; margin-left: 2rem; }
  .kd-nav a, .kd-mobile-nav a { padding: 0.375rem 0.875rem; font-size: 0.8125rem; font-weight: 500; color: #6B7280; border-radius: 0.375rem; transition: all 0.2s; text-decoration: none; }
  .kd-nav a:hover, .kd-mobile-nav a:hover { color: #0F172A; background: #F3F4F6; }
  :global([data-theme='dark']) .kd-nav a, :global([data-theme='dark']) .kd-mobile-nav a { color: #9CA3AF; }
  :global([data-theme='dark']) .kd-nav a:hover, :global([data-theme='dark']) .kd-mobile-nav a:hover { color: white; background: #374151; }
  .kd-nav a.active, .kd-mobile-nav a.active { color: #326CE5; background: #EBF1FF; font-weight: 600; }
  :global([data-theme='dark']) .kd-nav a.active, :global([data-theme='dark']) .kd-mobile-nav a.active { color: #93B4F5; background: rgba(50,108,229,0.15); }
  .kd-right { margin-left: auto; display: flex; align-items: center; gap: 0.5rem; }
  .kd-search { min-width: 10rem; }
  .kd-search :global(button) { border-radius: 0.5rem !important; height: 2rem !important; font-size: 0.8125rem !important; }
  .kd-theme :global(select), .kd-lang :global(select) { font-size: 0.75rem; }
  .kd-social :global(a) { color: #9CA3AF; } .kd-social :global(a:hover) { color: #0F172A; }
  :global([data-theme='dark']) .kd-social :global(a:hover) { color: white; }
  .kd-lang-link { color: #9CA3AF; text-decoration: none; font-size: 1rem; line-height: 1; padding: 0.25rem; }
  .kd-lang-link:hover { color: #0F172A; }
  :global([data-theme='dark']) .kd-lang-link:hover { color: white; }
  .kd-menu-toggle { display: none; border: 1px solid #D1D5DB; border-radius: 0.5rem; background: transparent; color: #4B5563; cursor: pointer; font-size: 0.75rem; font-weight: 600; padding: 0.45rem 0.75rem; }
  .kd-menu-toggle:hover { border-color: #9CA3AF; color: #0F172A; }
  :global([data-theme='dark']) .kd-menu-toggle { border-color: #4B5563; color: #D1D5DB; }
  :global([data-theme='dark']) .kd-menu-toggle:hover { border-color: #6B7280; color: white; }
  .kd-mobile-panel { display: none; border-bottom: 1px solid #E5E7EB; background: white; padding: 0.75rem 1rem 1rem; }
  :global([data-theme='dark']) .kd-mobile-panel { background: #1F2937; border-bottom-color: #374151; }
  .kd-mobile-panel:not([hidden]) { display: block; }
  .kd-mobile-nav { display: grid; gap: 0.375rem; }
  .kd-mobile-nav a { display: block; }

  @media (max-width: 50rem) {
    .kd-topbar { padding: 0 1rem; }
    .kd-nav, .kd-social, .kd-lang, .kd-lang-link { display: none; }
    .kd-search { min-width: 0; }
    .kd-search :global(button) { max-width: none; width: auto; }
    .kd-menu-toggle { display: inline-flex; align-items: center; justify-content: center; }
  }
</style>
