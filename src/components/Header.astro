---
/**
 * Custom Header — exact match to POC v2 topbar
 * Locale-aware: detects /uk/ prefix and switches labels + hrefs.
 */
import type { Props } from '@astrojs/starlight/props';
import Search from 'virtual:starlight/components/Search';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import LanguageSelect from 'virtual:starlight/components/LanguageSelect';

const isUk = Astro.url.pathname.startsWith('/uk/') || Astro.url.pathname === '/uk';
const p = isUk ? '/uk' : '';

const nav = isUk
  ? [
      [`${p}/`, 'Головна'],
      [`${p}/prerequisites/`, 'Основи'],
      [`${p}/linux/`, 'Linux'],
      [`${p}/cloud/`, 'Хмара'],
      [`${p}/ai-ml-engineering/`, 'AI/ML'],
      [`${p}/k8s/`, 'Сертифікації'],
      [`${p}/platform/`, 'Платформа'],
      [`${p}/on-premises/`, 'On-Premises'],
    ]
  : [
      ['/', 'Home'],
      ['/prerequisites/', 'Fundamentals'],
      ['/linux/', 'Linux'],
      ['/cloud/', 'Cloud'],
      ['/ai-ml-engineering/', 'AI/ML'],
      ['/k8s/', 'Certifications'],
      ['/platform/', 'Platform'],
      ['/on-premises/', 'On-Premises'],
    ];
---

<div class="kd-topbar">
  <a class="kd-logo" href={`${p}/` || '/'}><span class="kd-logo-icon">K</span><span>KubeDojo</span></a>
  <nav class="kd-nav">
    {nav.map(([href, label]) => <a href={href}>{label}</a>)}
  </nav>
  <div class="kd-right">
    <div class="kd-search"><Search {...Astro.props} /></div>
    <div class="kd-theme"><ThemeSelect {...Astro.props} /></div>
    <div class="kd-social"><SocialIcons {...Astro.props} /></div>
    <div class="kd-lang"><LanguageSelect {...Astro.props} /></div>
  </div>
</div>
<script>
  function hlNav() {
    const p = window.location.pathname;
    const isUk = p.startsWith('/uk/') || p === '/uk';
    const home = isUk ? '/uk/' : '/';
    document.querySelectorAll('.kd-nav a').forEach(a => {
      const h = a.getAttribute('href') || '';
      a.classList.toggle('active', h === home ? p === home : p.startsWith(h));
    });
  }
  hlNav(); document.addEventListener('astro:page-load', hlNav);
</script>

<style>
  /* Exact POC v2 values */
  .kd-topbar { background: white; border-bottom: 1px solid #E5E7EB; padding: 0 2rem; display: flex; align-items: center; height: 3.5rem; }
  :global([data-theme='dark']) .kd-topbar { background: #1F2937; border-bottom-color: #374151; }
  .kd-logo { font-weight: 800; font-size: 1.125rem; letter-spacing: -0.5px; display: flex; align-items: center; gap: 0.5rem; color: #0F172A; text-decoration: none; }
  :global([data-theme='dark']) .kd-logo { color: white; }
  .kd-logo-icon { width: 1.75rem; height: 1.75rem; background: #326CE5; border-radius: 0.4rem; display: flex; align-items: center; justify-content: center; color: white; font-size: 0.875rem; font-weight: 900; }
  .kd-nav { display: flex; gap: 0.25rem; margin-left: 2rem; }
  .kd-nav a { padding: 0.375rem 0.875rem; font-size: 0.8125rem; font-weight: 500; color: #6B7280; border-radius: 0.375rem; transition: all 0.2s; text-decoration: none; }
  .kd-nav a:hover { color: #0F172A; background: #F3F4F6; }
  :global([data-theme='dark']) .kd-nav a { color: #9CA3AF; }
  :global([data-theme='dark']) .kd-nav a:hover { color: white; background: #374151; }
  .kd-nav a.active { color: #326CE5; background: #EBF1FF; font-weight: 600; }
  :global([data-theme='dark']) .kd-nav a.active { color: #93B4F5; background: rgba(50,108,229,0.15); }
  .kd-right { margin-left: auto; display: flex; align-items: center; gap: 0.5rem; }
  .kd-search { min-width: 10rem; }
  .kd-search :global(button) { border-radius: 0.5rem !important; height: 2rem !important; font-size: 0.8125rem !important; }
  .kd-theme :global(select), .kd-lang :global(select) { font-size: 0.75rem; }
  .kd-social :global(a) { color: #9CA3AF; } .kd-social :global(a:hover) { color: #0F172A; }
  :global([data-theme='dark']) .kd-social :global(a:hover) { color: white; }
  @media (max-width: 50rem) { .kd-nav { display: none; } .kd-topbar { padding: 0 1rem; } }
</style>
