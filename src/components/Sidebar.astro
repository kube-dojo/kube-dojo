---
/**
 * Custom Sidebar — exact match to POC v2
 * Section title with dot, part headers, monospace numbers, blue active, checkmarks
 */
import type { Props } from '@astrojs/starlight/props';
import MobileMenuFooter from 'virtual:starlight/components/MobileMenuFooter';

const { sidebar } = Astro.locals.starlightRoute;

function getModNum(label: string): string | null {
  const m = label.match(/^Module\s+(\d+\.?\d*)/i);
  return m ? m[1] : null;
}

function cleanLabel(label: string): string {
  return label.replace(/^Module\s+\d+\.?\d*[:\s\-]*/i, '').trim() || label;
}

function hasCurrent(entries: any[]): boolean {
  for (const e of entries) {
    if (e.type === 'link' && e.isCurrent) return true;
    if (e.type === 'group' && hasCurrent(e.entries)) return true;
  }
  return false;
}

function isLeafGroup(entry: any): boolean {
  if (entry.type !== 'group') return false;
  // A leaf group contains only links (no nested groups)
  return entry.entries.every((e: any) => e.type === 'link');
}

/** Check if a group's label looks like a "Part" (part0-environment style from autogenerate) */
function isPartLevelGroup(entry: any): boolean {
  if (entry.type !== 'group') return false;
  // Starlight autogenerate labels use the sidebar.label from the index.md
  // These are groups like "Part 0: Environment Setup", "Part 1: Cluster Architecture"
  // They contain modules as links
  return true; // At this depth, all groups are parts
}

function renderLink(e: any): string {
  const modNum = getModNum(e.label);
  const label = modNum ? cleanLabel(e.label) : e.label;
  const cls = e.isCurrent ? 'kd-sl active' : 'kd-sl';
  const aria = e.isCurrent ? ' aria-current="page"' : '';
  const num = modNum ? `<span class="kd-sn">${modNum}</span>` : '';
  return `<a href="${e.href}" class="${cls}"${aria}>${num}<span>${label}</span></a>`;
}

function renderEntry(entry: any, depth: number = 0): string {
  if (entry.type === 'link') return renderLink(entry);

  const isOpen = hasCurrent(entry.entries) || !entry.collapsed;
  const caret = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>';

  // All groups: collapsible toggle with clean label
  // Fix raw directory name labels using the index page's label
  const isRawName = entry.label.includes('-') && !entry.label.includes(':') && !entry.label.includes(' ');
  const indexLink = isRawName ? entry.entries.find((e: any) => e.type === 'link' && !getModNum(e.label)) : null;
  const groupLabel = (isRawName && indexLink) ? indexLink.label : entry.label;

  // Filter out index page from children (it duplicates the group toggle)
  const filteredEntries = indexLink ? entry.entries.filter((e: any) => e !== indexLink) : entry.entries;
  const children = filteredEntries.map((e: any) => renderEntry(e, depth + 1)).join('');

  // If there's an index page, make the label a clickable link too
  const labelHtml = indexLink
    ? `<a href="${indexLink.href}" class="kd-sg-link" onclick="event.stopPropagation()">${groupLabel}</a>`
    : groupLabel;

  return `<details${isOpen ? ' open' : ''}>
    <summary class="kd-sg">${labelHtml}${caret}</summary>
    <div class="kd-sc">${children}</div>
  </details>`;
}

// Best UX practice: Show the second level (subsections within a track).
// All siblings visible. Active one will auto-expand via Starlight's `open` attribute.
//
// Examples:
//   In CKA Part 3 Module 3.4 → show CKA level (all Parts visible, Part 3 expanded)
//   In SRE → show Disciplines level (all disciplines visible, SRE expanded)
//   In Zero to Terminal → show Fundamentals level (all sections visible, ZtT expanded)
//
// Drill: Track (depth 0) → Subsection (depth 1) → STOP
// Exception: if depth 1 has only 1-3 children AND those children have sub-groups, go one deeper
function findActiveBranch(entries: any[]): { label: string; entries: any[] } | null {
  for (const e of entries) {
    if (e.type !== 'group' || !hasCurrent(e.entries || [])) continue;

    // Find the active child
    const activeChild = e.entries.find((c: any) => c.type === 'group' && hasCurrent(c.entries || []));

    if (activeChild) {
      // Check if this level has very few children that each have sub-groups
      // (like Platform with just Foundations/Disciplines/Toolkits — go one deeper)
      const childGroups = e.entries.filter((c: any) => c.type === 'group');
      const hasDeepChildren = childGroups.some((c: any) => c.entries?.some((gc: any) => gc.type === 'group'));

      if (childGroups.length <= 3 && hasDeepChildren) {
        // Too few items at this level (Platform has 3) — go deeper
        const deeper = findActiveBranch(e.entries);
        if (deeper) return deeper;
      }
    }

    // This is the right level — show all children, active one will be expanded
    // Clean raw directory name labels
    const isRawLabel = e.label.includes('-') && !e.label.includes(':') && !e.label.includes(' ');
    const idxLink = isRawLabel ? e.entries.find((c: any) => c.type === 'link' && !getModNum(c.label)) : null;
    const cleanedLabel = (isRawLabel && idxLink) ? idxLink.label : e.label;
    return { label: cleanedLabel, entries: e.entries };
  }
  return null;
}

const currentBranch = findActiveBranch(sidebar);
const section = currentBranch?.label || '';
const entriesToRender = currentBranch ? currentBranch.entries : sidebar;
---

<div class="kd-sb">
  {section && <div class="kd-st"><span class="kd-dot"></span><span>{section}</span></div>}
  <Fragment set:html={entriesToRender.map((e: any) => renderEntry(e)).join('')} />
</div>
<div class="md:sl-hidden"><MobileMenuFooter /></div>

<style>
  /* Exact POC v2 sidebar values */
  .kd-sb { font-size: 0.8125rem; padding: 0 0.5rem; }

  /* Section title with blue dot */
  .kd-st { font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.8px; color: #9CA3AF; padding: 0.5rem 0.75rem; display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.25rem; }
  .kd-dot { width: 6px; height: 6px; border-radius: 2px; background: #326CE5; flex-shrink: 0; }

  /* Group toggle — clean bordered button */
  .kd-sb :global(summary.kd-sg) {
    display: flex; align-items: center; justify-content: space-between;
    border: 1px solid #E5E7EB; border-radius: 8px; padding: 0.4rem 0.75rem;
    font-weight: 600; font-size: 0.875rem; cursor: pointer; user-select: none;
    background: transparent; color: inherit; list-style: none;
    transition: all 0.15s; margin-bottom: 0.25rem;
  }
  :global([data-theme='dark']) .kd-sb :global(summary.kd-sg) { border-color: #374151; }
  .kd-sb :global(summary.kd-sg:hover) { background: #EBF1FF; border-color: #326CE5; }
  :global([data-theme='dark']) .kd-sb :global(summary.kd-sg:hover) { background: rgba(50,108,229,0.15); }
  .kd-sb :global(summary.kd-sg::marker), .kd-sb :global(summary.kd-sg::-webkit-details-marker) { display: none; }
  /* Group label as link */
  .kd-sb :global(.kd-sg-link) { color: inherit; text-decoration: none; }
  .kd-sb :global(.kd-sg-link:hover) { color: #326CE5; text-decoration: none; }

  .kd-sb :global(summary.kd-sg svg) { transition: transform 0.2s; color: #9CA3AF; flex-shrink: 0; }
  .kd-sb :global(details[open] > summary.kd-sg svg) { transform: rotate(90deg); }

  /* Children container */
  .kd-sb :global(.kd-sc) { margin-left: 0.5rem; padding-left: 0.5rem; border-left: 1px solid #E5E7EB; }
  :global([data-theme='dark']) .kd-sb :global(.kd-sc) { border-left-color: #374151; }

  /* Nested group toggles smaller */
  .kd-sb :global(.kd-sc summary.kd-sg) { font-size: 0.8125rem; padding: 0.3rem 0.625rem; }

  /* Part headers — bold, not collapsible */
  .kd-sb :global(.kd-ph) {
    display: block; font-weight: 700; font-size: 0.75rem; color: #374151;
    padding: 0.625rem 0.75rem 0.25rem; margin-top: 0.5rem; text-decoration: none; border-radius: 0.375rem;
  }
  :global([data-theme='dark']) .kd-sb :global(.kd-ph) { color: #D1D5DB; }
  .kd-sb :global(a.kd-ph:hover) { background: #F3F4F6; }
  :global([data-theme='dark']) .kd-sb :global(a.kd-ph:hover) { background: #374151; }
  .kd-sb :global(.kd-ph-active) { color: #326CE5 !important; background: #EBF1FF; }
  :global([data-theme='dark']) .kd-sb :global(.kd-ph-active) { color: #93B4F5 !important; background: rgba(50,108,229,0.15); }

  /* Links */
  .kd-sb :global(a.kd-sl) {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.3rem 0.75rem; border-radius: 0.375rem;
    color: #4B5563; text-decoration: none; line-height: 1.4; transition: all 0.15s;
  }
  :global([data-theme='dark']) .kd-sb :global(a.kd-sl) { color: #9CA3AF; }
  .kd-sb :global(a.kd-sl:hover) { color: #0F172A; background: #F3F4F6; }
  :global([data-theme='dark']) .kd-sb :global(a.kd-sl:hover) { color: white; background: #374151; }
  .kd-sb :global(a.kd-sl.active) { font-weight: 600; color: #326CE5; background: #EBF1FF; }
  :global([data-theme='dark']) .kd-sb :global(a.kd-sl.active) { color: #93B4F5; background: rgba(50,108,229,0.15); }

  /* Module numbers */
  .kd-sb :global(.kd-sn) { font-family: var(--sl-font-mono); font-size: 0.6875rem; color: #9CA3AF; min-width: 1.75rem; flex-shrink: 0; }
  .kd-sb :global(a.kd-sl.active .kd-sn) { color: #326CE5; }
  :global([data-theme='dark']) .kd-sb :global(a.kd-sl.active .kd-sn) { color: #93B4F5; }

  /* Spacing */
  .kd-sb :global(details + details), .kd-sb :global(details + a), .kd-sb :global(a + details), .kd-sb :global(a + a) { margin-top: 0.25rem; }

  /* Progress checkmarks on completed sidebar links */
  .kd-sb :global(a[data-completed="true"])::after { content: ' ✓'; color: #00A651; font-weight: 700; font-size: 0.75rem; margin-left: auto; }
</style>
