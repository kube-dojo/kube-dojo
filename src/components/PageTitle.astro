---
/**
 * Custom PageTitle — breadcrumbs + title + lab banner + progress bar on index pages
 */
import type { Props } from '@astrojs/starlight/props';
import LabBanner from './LabBanner.astro';
import LabProgressBar from './LabProgressBar.astro';
import RevisionBanner from './RevisionBanner.astro';
const PAGE_TITLE_ID = '_top';
const route = Astro.locals.starlightRoute;
const title = route.entry.data.title;
const lab = (route.entry.data as any).lab;
const revisionPending = (route.entry.data as any).revision_pending === true;

// Lab progress bars for index pages — prefix → total labs in that section
const labTrackMap: Record<string, { prefix: string; total: number }> = {
  'prerequisites/zero-to-terminal': { prefix: 'prereq-0.', total: 5 },
  'prerequisites/kubernetes-basics': { prefix: 'prereq-k8s-', total: 5 },
  'linux/foundations/everyday-use': { prefix: 'linux-0.', total: 5 },
  'linux/foundations/system-essentials': { prefix: 'linux-1.', total: 4 },
  'linux/foundations/networking': { prefix: 'linux-3.', total: 4 },
  'k8s/cka/part0-environment': { prefix: 'cka-0.', total: 5 },
  'k8s/cka/part1-cluster-architecture': { prefix: 'cka-1.', total: 7 },
  'k8s/cka/part2-workloads-scheduling': { prefix: 'cka-2.', total: 9 },
  'k8s/cka/part3-services-networking': { prefix: 'cka-3.', total: 8 },
  'k8s/cka/part4-storage': { prefix: 'cka-4.', total: 5 },
  'k8s/cka/part5-troubleshooting': { prefix: 'cka-5.', total: 7 },
  'k8s/ckad/part0-environment': { prefix: 'ckad-0.', total: 2 },
  'k8s/ckad/part1-design-build': { prefix: 'ckad-1.', total: 4 },
  'k8s/ckad/part2-deployment': { prefix: 'ckad-2.', total: 4 },
  'k8s/ckad/part3-observability': { prefix: 'ckad-3.', total: 5 },
  'k8s/ckad/part4-environment': { prefix: 'ckad-4.', total: 6 },
  'k8s/ckad/part5-networking': { prefix: 'ckad-5.', total: 3 },
  'k8s/cks/part0-environment': { prefix: 'cks-0.', total: 4 },
  'k8s/cks/part1-cluster-setup': { prefix: 'cks-1.', total: 5 },
  'k8s/cks/part2-cluster-hardening': { prefix: 'cks-2.', total: 5 },
  'k8s/cks/part3-system-hardening': { prefix: 'cks-3.', total: 4 },
  'k8s/cks/part4-microservice-vulnerabilities': { prefix: 'cks-4.', total: 4 },
  'k8s/cks/part5-supply-chain-security': { prefix: 'cks-5.', total: 4 },
  'k8s/cks/part6-runtime-security': { prefix: 'cks-6.', total: 4 },
  'linux/security/hardening': { prefix: 'linux-4.', total: 4 },
  'linux/operations/performance': { prefix: 'linux-5.', total: 4 },
  'linux/operations/troubleshooting': { prefix: 'linux-6.', total: 4 },
  'linux/operations/shell-scripting': { prefix: 'linux-7.', total: 4 },
  'linux/operations': { prefix: 'linux-8.', total: 4 },
};
const slug = route.slug || '';

// Use URL pathname to detect index pages (slug can be empty for index pages)
const pathname = Astro.url.pathname.replace(/^\/uk/, '').replace(/^\/|\/$/g, '');
const isModulePage = pathname.includes('/module-');
const trackKey = Object.keys(labTrackMap).find(k => pathname.includes(k));
const labTrack = !isModulePage && trackKey ? labTrackMap[trackKey] : null;
const isUk = Astro.url.pathname.startsWith('/uk/') || Astro.url.pathname === '/uk';
// Strip 'uk/' prefix from parts so breadcrumbs work the same way
const rawParts = slug.split('/').filter(Boolean);
const parts = (rawParts[0] === 'uk') ? rawParts.slice(1) : rawParts;

const enLabels: Record<string, string> = {
  'k8s': 'Certifications', 'platform': 'Platform', 'prerequisites': 'Fundamentals',
  'cloud': 'Cloud', 'linux': 'Linux', 'on-premises': 'On-Premises',
  'cka': 'CKA', 'ckad': 'CKAD', 'cks': 'CKS', 'kcna': 'KCNA', 'kcsa': 'KCSA',
  'extending': 'Extending K8s', 'disciplines': 'Disciplines', 'foundations': 'Foundations',
  'toolkits': 'Toolkits', 'sre': 'SRE', 'gitops': 'GitOps', 'devsecops': 'DevSecOps',
  'mlops': 'MLOps', 'aiops': 'AIOps', 'finops': 'FinOps', 'iac': 'IaC',
};

const ukLabels: Record<string, string> = {
  'k8s': 'Сертифікації', 'platform': 'Платформа', 'prerequisites': 'Основи',
  'cloud': 'Хмара', 'linux': 'Linux', 'on-premises': 'On-Premises',
  'cka': 'CKA', 'ckad': 'CKAD', 'cks': 'CKS', 'kcna': 'KCNA', 'kcsa': 'KCSA',
  'extending': 'Розширення K8s', 'disciplines': 'Дисципліни', 'foundations': 'Основи',
  'toolkits': 'Інструменти', 'sre': 'SRE', 'gitops': 'GitOps', 'devsecops': 'DevSecOps',
  'mlops': 'MLOps', 'aiops': 'AIOps', 'finops': 'FinOps', 'iac': 'IaC',
};

const labelMap = isUk ? ukLabels : enLabels;

// Map part directories to clean labels: "part3-services-networking" → "Part 3: Services & Networking"
function cleanPart(s: string): string {
  const m = s.match(/^part(\d+)-(.+)/);
  if (m) return `Part ${m[1]}: ${m[2].replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase())}`;
  return labelMap[s] || s.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
}

const crumbs: { label: string; href: string }[] = [];
const prefix = isUk ? '/uk' : '';
if (parts.length > 1) {
  let path = prefix;
  for (let i = 0; i < parts.length - 1; i++) {
    path += '/' + parts[i];
    const label = labelMap[parts[i]] || cleanPart(parts[i]);
    crumbs.push({ label, href: path + '/' });
  }
}
---

{crumbs.length > 0 && (
  <nav class="kd-bc" aria-label="Breadcrumb">
    {crumbs.map((c) => (
      <><a href={c.href}>{c.label}</a><span class="kd-bc-sep">/</span></>
    ))}
    <span class="kd-bc-cur">{parts[parts.length - 1]?.replace(/-/g, ' ').replace(/^module \d+\.?\d* /i, '').slice(0, 40)}</span>
  </nav>
)}
<h1 id={PAGE_TITLE_ID} class="kd-title">{title}</h1>

{revisionPending && <RevisionBanner />}

{labTrack && (
  <LabProgressBar prefix={labTrack.prefix} total={labTrack.total} />
)}

{lab && (
  <LabBanner
    id={lab.id}
    url={lab.url}
    duration={lab.duration}
    difficulty={lab.difficulty}
    environment={lab.environment}
  />
)}

<style>
  /* Exact POC v2 values */
  .kd-bc { display: flex; align-items: center; gap: 0.375rem; font-size: 0.75rem; color: #9CA3AF; margin-bottom: 0.75rem; flex-wrap: wrap; }
  .kd-bc a { color: #9CA3AF; text-decoration: none; } .kd-bc a:hover { color: #326CE5; }
  .kd-bc-sep { opacity: 0.5; }
  .kd-bc-cur { color: #9CA3AF; }
  .kd-title { margin-top: 0; font-size: 2rem; font-weight: 800; letter-spacing: -0.5px; line-height: var(--sl-line-height-headings); color: var(--sl-color-white); }
</style>
