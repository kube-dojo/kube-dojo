---
/**
 * Custom PageTitle — adds breadcrumbs above the title (Gap #1)
 */
const PAGE_TITLE_ID = '_top';

const route = Astro.locals.starlightRoute;
const title = route.entry.data.title;
const slug = route.slug || '';

// Build breadcrumb from slug: "k8s/cka/part3-services-networking/module-3.4-ingress"
// → ["k8s", "cka", "part3-services-networking", "module-3.4-ingress"]
const parts = slug.split('/').filter(Boolean);
const crumbs: { label: string; href: string }[] = [];

if (parts.length > 1) {
  let path = '';
  for (let i = 0; i < parts.length - 1; i++) {
    path += '/' + parts[i];
    // Clean up the label
    let label = parts[i]
      .replace(/^part\d+-/, 'Part: ')
      .replace(/-/g, ' ')
      .replace(/\b\w/g, (c: string) => c.toUpperCase());
    // Short labels for known sections
    if (parts[i] === 'k8s') label = 'Certifications';
    if (parts[i] === 'platform') label = 'Platform';
    if (parts[i] === 'prerequisites') label = 'Fundamentals';
    if (parts[i] === 'cloud') label = 'Cloud';
    if (parts[i] === 'linux') label = 'Linux';
    if (parts[i] === 'on-premises') label = 'On-Premises';
    crumbs.push({ label, href: path + '/' });
  }
}
---

{crumbs.length > 0 && (
  <nav class="kd-breadcrumb" aria-label="Breadcrumb">
    {crumbs.map((crumb, i) => (
      <>
        <a href={crumb.href}>{crumb.label}</a>
        <span class="kd-bc-sep">/</span>
      </>
    ))}
    <span class="kd-bc-current">{parts[parts.length - 1]?.replace(/-/g, ' ').replace(/^module \d+\.?\d* /i, '')}</span>
  </nav>
)}

<h1 id={PAGE_TITLE_ID} class="kd-page-title">{title}</h1>

<style>
  .kd-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    color: var(--sl-color-gray-3);
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }
  .kd-breadcrumb a {
    color: var(--sl-color-gray-3);
    text-decoration: none;
  }
  .kd-breadcrumb a:hover {
    color: var(--sl-color-accent);
  }
  .kd-bc-sep {
    color: var(--sl-color-gray-3);
    opacity: 0.5;
  }
  .kd-bc-current {
    color: var(--sl-color-gray-3);
  }
  .kd-page-title {
    margin-top: 0;
    font-size: 2rem;
    line-height: var(--sl-line-height-headings);
    font-weight: 800;
    color: var(--sl-color-white);
    letter-spacing: -0.5px;
  }
</style>
