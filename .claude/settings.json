{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoCompactWindow": 1000000,
  "env": {
    "ENABLE_PROMPT_CACHING_1H": "1"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{"type": "command", "command": ".claude/hooks/enforce-venv.sh"}]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [{"type": "command", "command": ".claude/hooks/context-monitor.sh"}]
      }
    ],
    "SessionStart": [
      {
        "hooks": [{"type": "command", "command": ".claude/hooks/session-setup.sh"}]
      }
    ],
    "PostCompact": [
      {
        "hooks": [{"type": "command", "command": ".claude/hooks/post-compact.sh"}]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh issue *)",
      "Bash(gh pr *)",
      "Bash(gh api *)",
      "Bash(gh run *)",
      "Bash(gh workflow *)",
      "Bash(npm run *)",
      "Bash(make *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pip install *)",
      "Bash(pip show *)",
      "Bash(source .venv/bin/activate *)",
      "Bash(mkdocs *)",
      "Bash(bash *)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(mkdir *)",
      "Bash(curl *)",
      "Bash(chmod *)",
      "Bash(sort *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(sed *)",
      "Bash(kill *)",
      "Bash(lsof *)",
      "Bash(ps *)",
      "Bash(sleep *)",
      "Bash(test *)",
      "Bash(echo *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(npx markdownlint-cli2 *)",
      "Bash(scripts/ab *)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)"
    ]
  }
}
